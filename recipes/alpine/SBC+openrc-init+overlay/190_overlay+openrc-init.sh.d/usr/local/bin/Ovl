#!/bin/sh
# (C) 2025 Joerg Jungermann, GPLv2 see LICENSE
set -eu

OVERLAY_DIR=/overlay/upper
ROM_DIR=/rom
ETCKEEPER_EXCLUDES="etc/.git | etc/.git/* | etc/.etckeeper"

export LC_ALL=C
export LANG=C

list_files() {
  list_files_collector "$@" | \
    list_files_filter "$@" | \
    list_files_action "$@"
  }

list_files_collector() ( # use brackets for true forked subshell
  cd "$OVERLAY_DIR"

  find_opts=
  find_dirs=
  dirs_added=no
  while [ ! $# = 0 ]; do # command line passing carefully
    case "${1:-}" in
      "!" ) find_opts="$find_opts '!'" ;;
      --type | -t )
        shift
        case "${1:-}" in
          f | d ) find_opts="$find_opts -type '$1'"
        esac
        ;;
      -name | -n )
        shift
        find_opts="$find_opts -name '$1'"
        ;;
      -a | -o )
        find_opts="$find_opts $1"
        ;;

      --help | -h | -[?] ) help return 69 ;;
      -* ) ;;

      * )
        f="${1}"
        [ ! "$1" = / ] || f="."
        dirs_added=yes
        if [ -e "${f#/}" ]; then
          find_dirs="${find_dirs} '${f#/}'"
        else
          echo "W: '$f' not found in overlay, at all. No file, no dir nor a wipeout file, SKIP" >&2
        fi
        ;;
    esac
    shift
  done

  if [ "$dirs_added" = no ]; then
    #find_dirs="etc usr/local opt srv"
    find_dirs="." # use / per default
    find_dirs=$( cd "$OVERLAY_DIR"; ls -1d $find_dirs 2> /dev/null || :)
    find_dirs=$( echo $find_dirs 2> /dev/null || :)
  fi

  [ -z "$find_dirs" ] || \
    eval "find $find_dirs $find_opts" | sort -r
  )

list_files_filter() {
  select_modified=
  select_obsolete=
  select_new=
  select_deleted=
  while [ ! $# = 0 ]; do # command line passing carefully
    case "${1:-}" in
      --help | -h | -[?] ) return  69 ;; # NOP with help
      --etckeeper | -E ) ETCKEEPER_EXCLUDES="" ;;
      --mod | --diff ) select_modified=yes ;;
      --new ) select_new=yes ;;
      --obsolete | --obs | --gc ) select_obsolete=yes ;;
      --deleted | --del ) select_deleted=yes ;;
    esac
    shift
  done
  while read f; do
    case "$f" in
      . | .. ) continue ;;
    esac

    f="${f#./}"
    excludes="$ETCKEEPER_EXCLUDES"
    e=
    if [ -n "$excludes" ]; then
      eval "
        case '$f' in
          $excludes ) continue ;; # in exclude list
        esac
      "
    fi

    stat="-?-"
    kind="-"

    # directory | regular file | character special file | block special file | symbolic link
    kind_stat="$( stat -c "%t:%T:%a:%U:%G:%F" "$OVERLAY_DIR/$f" 2> /dev/null )"
    case "${kind_stat##*:}" in
      dir* )   kind="D" ;;
      reg* )   kind="F" ;;
      char* )  kind="c" ;;
      block* ) kind="b" ;;
      sym* )   kind="L" ;;
    esac

    if [ ! -e "$ROM_DIR/$f" ]; then
      stat=".N."
      case "${kind_stat}" in
        0:0:*char* )
          kind="-"
          stat="..."
          ;;
      esac
    else
      case "${kind_stat}" in
        0:0:*char* )
          kind="-"
          stat=".D."
          ;;
        *:dir* )
          stat="..."
          kind_rom_stat="$( stat -c "%t:%T:%a:%U:%G:%F" "$ROM_DIR/$f" 2> /dev/null || : )"
          [ "${kind_stat}" = "${kind_rom_stat}" ] || \
            stat="..p"
          ;;
        *:sym* )
          stat="..."
          kind_readlink="$( readlink "$OVERLAY_DIR/$f" 2> /dev/null || : )"
          kind_rom_readlink="$( readlink "$ROM_DIR/$f" 2> /dev/null || : )"
          [ "${kind_readlink}" = "${kind_rom_readlink}" ] || \
            stat="d.."
          ;;
        *:reg* )
          stat="..."
          kind_rom_stat="$( stat -c "%t:%T:%a:%U:%G:%F" "$ROM_DIR/$f" 2> /dev/null || : )"
          [ "${kind_stat}" = "${kind_rom_stat}" ] || \
            stat="${stat%[.-]}p"
          if ! cmp -s "$ROM_DIR/$f" "$OVERLAY_DIR/$f"; then
            stat="M${stat#[.-]}"
          fi
          ;;
        * )
          kind_rom_stat="$( stat -c "%t:%T:%a:%U:%G:%F" "$ROM_DIR/$f" 2> /dev/null || : )"
          [ "${kind_stat##*:}" = "${kind_rom_stat##*:}" ] || \
            stat=".T."
          ;;
        esac
    fi

    case "$select_modified:$stat:$kind" in
      yes:M??:F ) ;;
      yes:?D?:* ) ;;
      yes:* ) continue ;;
    esac

    case "$select_new:$stat" in
      yes:?N?  ) ;;
      yes:* ) continue ;;
    esac

    case "$select_obsolete:$stat" in
      yes:...  ) ;;
      yes:* ) continue ;;
    esac

    case "$select_deleted:$stat" in
      yes:?D?) ;;
      yes:* ) continue ;;
    esac

    echo "$stat  $kind  $f"
  done
  }

list_files_do_list() {
  echo "  $1   $2   $3"
  }

list_files_do_diff() {
  old="$ROM_DIR/$3"
  new="$OVERLAY_DIR/$3"
  # new files
  if [ -f "$new" ] || [ -L "$new" ]; then
    if [ ! -f "$old" ] && [ ! -L "$old" ]; then
      old=/dev/null
    fi
  # files delete from rootfs but present $ROM_DIR
  elif [ "$1" = ".D." ]; then
      new=/dev/null
  fi
  diff --no-dereference -ua "$old" "$new" || :
  }
list_files_do_garbage_collection() {
  case "$NOP:$1:$2" in
    *:...:D ) rmdir "$OVERLAY_DIR/$3" 2>/dev/null || : ;;
    #
    yes:...:? )
      list_files_do_list "$1" "$2" "$3"
      echo "'$3': would delete from overlay"
      ;;
    no:...:? )  ( set -x; rm -f "$OVERLAY_DIR/$3" ) ;;
  esac
  }

list_files_action() {
  MODE=list
  NOP=yes
  while [ ! $# = 0 ]; do # command line passing carefully
    case "${1:-}" in
      --help | -h | -[?] ) return 69 ;; # NOP with help
      --gc ) MODE=gc ;;
      --diff ) MODE=diff ;;
      --yes ) NOP=no ;;
    esac
    shift
  done
  while read i; do
    set -- $i
    # STAT  KIND  FILE
    case "$MODE" in
      list ) list_files_do_list "$1" "$2" "$3" ;;
      diff ) list_files_do_diff "$1" "$2" "$3" ;;
      gc   ) list_files_do_garbage_collection "$1" "$2" "$3" ;;
      * ) echo "E: list_files_action(): this should not have happended, ABORT" >&2 ;;
    esac
  done
  }

help() {
  echo "
    ${0##*/} [OPTIONS] [DIR] [DIR] ...

      Tool to inspect, diff or garbage collect changes to rootfs by comparing
      $OVERLAY_DIR with $ROM_DIR.

    Options:
      Filters:
        --type TYPE | -t TYPE   select file types (see find)
                                  l links
                                  d dirs
                                  f files
        --name GLOB | -n GLOB   select files based on a glob
        -a | -o                 logical AND and OR for above filters (compare to find)
        --deleted | --del       select files deleted in overlay, not existing
                                in '$ROM_DIR' anymore
        --obsolete | --obs      select files which have the same
                                  * data
                                  * metadata (modes, owner)
                                also select files deleted in '$ROM_DIR'
                                (see --del, eg after OS upgrade cleanup)
        --mod                   select modified files (content or metadata changes)
        --new                   select files only in '$OVERLAY_DIR'

      Filter options:
        --etckeeper | -E        Normally files below etckeeper files
                                are ignored, this can be overriden
          '$ETCKEEPER_EXCLUDES'

      Actions:
        --diff                 unified diff, selects modified files
        --gc                   remove obsolete files in overlay
                               (to do anything harmful, use --yes, default is NOP)

        * default action is 'list', just to display attributes

    " >&2
  exit 69
  }

SCRIPT="$0"
list_files "$@"

# vim: ts=2 sw=2 et foldmethod=indent ft=sh
